# Copy to .env for local runs:  cp .env.example .env
# (.env is gitignored — never commit real secrets.)

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Search provider: "tavily" (free, default) or "claude" (paid web_search).
# SEARCH_PROVIDER=tavily
# Free Tavily Search API key — https://app.tavily.com/ (no credit card).
# Required when SEARCH_PROVIDER=tavily.
TAVILY_API_KEY=tvly-...
# SEARCH_COUNT=12         # results fetched per query (more = more jobs)
# SEARCH_DEPTH=advanced   # "advanced" (better results) or "basic" (cheaper/shallower)

# ── Quality vs cost ──────────────────────────────────────────────────────────
# Models. RATE_MODEL does extraction + verification + scoring; Sonnet is the
# default for good quality at low cost. Drop to claude-haiku-4-5 for minimum cost,
# or claude-opus-4-8 for the sharpest scoring. CLAUDE_MODEL overrides both.
# SEARCH_MODEL=claude-haiku-4-5
# RATE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-8

# Verify each posting is live with web_fetch. true = filters expired jobs (more
# tokens); false = cheapest, snippets only. Jobs that can't be opened are kept
# and labelled "Unverified" in the email.
# VERIFY_POSTINGS=true
# FETCH_MAX_TOKENS=3000     # tokens pulled per fetched page (lower = cheaper)
# MAX_SEARCH_USES=3         # max web searches per query (claude provider)
# MAX_FETCH_USES=4          # max page fetches per query

# How recent a posting must be, in days (when the date is known). Default 14.
# MAX_POSTED_DAYS=14

# Gmail sender. GMAIL_APP_PASSWORD is a 16-char App Password, NOT your login
# password. Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account).
GMAIL_USER=snnov1980@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where to send the digest (defaults to GMAIL_USER if omitted)
MAIL_TO=snnov1980@gmail.com

# Only email jobs scoring >= this (1-10). Default 6.
# MIN_SCORE=6

# Max jobs in the email after sorting by score. Default 25.
# MAX_JOBS=25
